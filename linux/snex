#!/bin/bash
# ##################################################
# NAME:
#   snex
# DESCRIPTION:
#   snex previews and optionally executes snippets 
#   generated by snippet.
# AUTHOR:
#   bytebutcher
# ##################################################
if ! command -v snippet &>/dev/null; then
    echo "ERROR: snippet not found. Install with: pip install snippet-cli" >&2
    exit 1
fi

PARALLEL=0
MAX_PROCS=4
SNEX_ARGS=()

function usage() {
    cat <<'EOF'
usage: snex [-p] [-P MAX_PROCS] [SNIPPET_ARGS]...

Execute commands generated by snippet.

options:
  -p, --parallel        Execute commands in parallel (one per line)
  -P, --max-procs NUM   Max parallel processes (default: 4, implies -p)

All other arguments are forwarded to snippet. See 'snippet --help'.
EOF
}

function execute() {
    cmd="$1"
    if [[ "$PARALLEL" -eq 1 ]]; then
        echo "$cmd" | xargs -d '\n' --max-procs="$MAX_PROCS" -I CMD bash -c CMD
    else
        bash -c "$cmd"
    fi
}

function confirm() {
    echo         "----------------------------------------------------------------------" >&2
    read -rn1 -p "Execute command(s)? [y/N] " answer
    echo >&2
    case "$answer" in
        y|Y) return 0 ;;
        *)  echo "Aborted." >&2; return 1 ;;
    esac
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--parallel) PARALLEL=1; shift ;;
        -P|--max-procs) PARALLEL=1; MAX_PROCS="$2"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) SNEX_ARGS+=("$1"); shift ;;
    esac
done

if [ ${#SNEX_ARGS[@]} -eq 0 ] ; then
    usage
    exit 1
fi
cmd="$(snippet "${SNEX_ARGS[@]}")"
if [[ $? != 0 ]] || [ -z "$cmd" ] ; then
    # No command generated, aborting.
    exit 1
fi

# Preview command
echo "$cmd" >&2 && echo "" >&2

# Confirm and execute command
confirm && execute "$cmd"
